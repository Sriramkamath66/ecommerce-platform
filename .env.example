# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# Per-service databases (auto-created on first run)
USERS_DB=users_db
PRODUCTS_DB=products_db
ORDERS_DB=orders_db
INVENTORY_DB=inventory_db
PAYMENTS_DB=payments_db
NOTIFICATIONS_DB=notifications_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333

# ── JWT (RS256) ───────────────────────────────────────────────────────────────
# Generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY_PATH=/app/keys/private.pem
JWT_PUBLIC_KEY_PATH=/app/keys/public.pem
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── AI / LLM keys (optional — leave blank to skip; add later when available) ──
# Option A: Anthropic Claude + VoyageAI (original setup)
#   ANTHROPIC_API_KEY  → https://console.anthropic.com
#   VOYAGE_API_KEY     → https://dash.voyageai.com
# Option B: Google Gemini (free tier available at https://aistudio.google.com)
#   Set GOOGLE_API_KEY below and swap models when ready.
# Without any key: 7 core services work fully; semantic search returns empty;
# AI chat/recommendations return error responses instead of AI answers.
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=
GOOGLE_API_KEY=
LLM_MODEL=claude-opus-4-8
EMBEDDING_MODEL=voyage-3
EMBEDDING_DIMENSION=1024

# ── Service URLs (used for inter-service HTTP calls) ──────────────────────────
USER_SERVICE_URL=http://user-service:8001
PRODUCT_SERVICE_URL=http://product-service:8002
CART_SERVICE_URL=http://cart-service:8003
ORDER_SERVICE_URL=http://order-service:8004
INVENTORY_SERVICE_URL=http://inventory-service:8005
PAYMENT_SERVICE_URL=http://payment-service:8006
NOTIFICATION_SERVICE_URL=http://notification-service:8007
RECOMMENDATION_SERVICE_URL=http://recommendation-service:8008
AI_ASSISTANT_SERVICE_URL=http://ai-assistant-service:8009

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_FROM=noreply@ai-ecommerce.local

# ── Environment ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
