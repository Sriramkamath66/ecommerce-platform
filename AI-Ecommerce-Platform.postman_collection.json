          "name": "Create Chat Session",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('sessionId', json.session_id);",
                  "    console.log('sessionId set:', json.session_id);",
                  "}"
                ]
