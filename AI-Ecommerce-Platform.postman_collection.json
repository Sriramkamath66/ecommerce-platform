              "raw": "{{notificationServiceUrl}}/notifications/?page=1&page_size=20&unread_only=false",
              "host": ["{{notificationServiceUrl}}"],
              "path": ["notifications", ""],
              "query": [
                { "key": "page",        "value": "1" },
                { "key": "page_size",   "value": "20" },
                { "key": "unread_only", "value": "false" }
              ]
            },
            "description": "Returns paginated notification log for the current user. Sets {{notificationId}} from first result."
